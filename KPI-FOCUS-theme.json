{
  "name": "KPI-FOCUS",
  "dataColors": ["#00BCD4","#7C4DFF","#00E676","#FF5252","#FFD740","#40C4FF","#E040FB","#69F0AE"],
  "background": "#1E1E2E",
  "secondaryBackground": "#2A2A3E",
  "firstLevelElements": "#FFFFFF",
  "secondLevelElements": "#B0BEC5",
  "thirdLevelElements": "#3D3D5C",
  "fourthLevelElements": "#5C5C7A",
  "tableAccent": "#00BCD4",
  "good": "#00E676",
  "neutral": "#FFD740",
  "bad": "#FF5252",
  "textClasses": {
    "callout": {"fontSize": 32, "fontFace": "Segoe UI Light", "color": "#00BCD4"},
    "title":   {"fontSize": 14, "fontFace": "Segoe UI Semibold", "color": "#FFFFFF"},
    "header":  {"fontSize": 11, "fontFace": "Segoe UI", "color": "#B0BEC5"},
    "label":   {"fontSize": 10, "fontFace": "Segoe UI", "color": "#B0BEC5"}
  },
  "visualStyles": {
    "*": {"*": {
      "general": [{"keepLayerOrder": true}],
      "background": [{"show": true, "color": {"solid": {"color": "#2A2A3E"}}, "transparency": 0}],
      "border": [{"show": true, "color": {"solid": {"color": "#00BCD4"}}, "radius": 8}],
      "dropShadow": [{"show": true, "color": {"solid": {"color": "#00BCD4"}}, "shadowBlur": 12, "shadowDistance": 0, "transparency": 80, "position": "Outer"}],
      "visualHeader": [{"show": false}],
      "title": [{"show": true}],
      "legend": [{"show": true, "position": "Top", "labelColor": {"solid": {"color": "#B0BEC5"}}, "fontFamily": "Segoe UI", "fontSize": 10}]
    }},
    "lineChart": {"*": {
      "categoryAxis": [{"show": true, "labelColor": {"solid": {"color": "#B0BEC5"}}, "fontSize": 10, "fontFamily": "Segoe UI", "showAxisTitle": false, "gridlineShow": false}],
      "valueAxis": [{"show": true, "labelColor": {"solid": {"color": "#B0BEC5"}}, "fontSize": 10, "fontFamily": "Segoe UI", "showAxisTitle": false, "gridlineShow": true, "gridlineColor": {"solid": {"color": "#3D3D5C"}}, "gridlineThickness": 1, "gridlineStyle": "dashed"}],
      "lineStyles": [{"strokeWidth": 2, "lineStyle": "solid", "showMarker": true, "markerShape": "circle", "markerSize": 5}],
      "plotArea": [{"transparency": 0}],
      "legend": [{"show": true, "position": "Top"}]
    }},
    "clusteredColumnChart": {"*": {
      "categoryAxis": [{"show": true, "labelColor": {"solid": {"color": "#B0BEC5"}}, "fontSize": 10, "fontFamily": "Segoe UI", "showAxisTitle": false, "innerPadding": 20}],
      "valueAxis": [{"show": true, "labelColor": {"solid": {"color": "#B0BEC5"}}, "fontSize": 10, "showAxisTitle": false, "gridlineShow": true, "gridlineColor": {"solid": {"color": "#3D3D5C"}}, "gridlineThickness": 1, "gridlineStyle": "dashed"}],
      "plotArea": [{"transparency": 0}],
      "legend": [{"show": false}]
    }},
    "clusteredBarChart": {"*": {
      "categoryAxis": [{"show": true, "labelColor": {"solid": {"color": "#B0BEC5"}}, "fontSize": 10, "fontFamily": "Segoe UI", "innerPadding": 22, "showAxisTitle": false}],
      "valueAxis": [{"show": true, "labelColor": {"solid": {"color": "#B0BEC5"}}, "showAxisTitle": false, "gridlineShow": true, "gridlineColor": {"solid": {"color": "#3D3D5C"}}, "gridlineThickness": 1}],
      "plotArea": [{"transparency": 0}]
    }},
    "donutChart": {"*": {
      "legend": [{"show": true, "position": "Right", "labelColor": {"solid": {"color": "#B0BEC5"}}, "fontSize": 10}]
    }},
    "pieChart": {"*": {
      "legend": [{"show": true, "position": "Right", "labelColor": {"solid": {"color": "#B0BEC5"}}, "fontSize": 10}]
    }},
    "tableEx": {"*": {
      "grid": [{"gridVertical": false, "gridHorizontal": true, "gridHorizontalColor": {"solid": {"color": "#3D3D5C"}}, "gridHorizontalWeight": 1, "outlineColor": {"solid": {"color": "#00BCD4"}}, "rowPadding": 4, "textSize": 11}],
      "columnHeaders": [{"fontColor": {"solid": {"color": "#1E1E2E"}}, "backColor": {"solid": {"color": "#00BCD4"}}, "outline": "BottomOnly", "autoSizeColumnWidth": true, "fontFamily": "Segoe UI Semibold", "fontSize": 11}],
      "values": [{"fontColorPrimary": {"solid": {"color": "#FFFFFF"}}, "backColorPrimary": {"solid": {"color": "#2A2A3E"}}, "fontColorSecondary": {"solid": {"color": "#B0BEC5"}}, "backColorSecondary": {"solid": {"color": "#1E1E2E"}}, "fontFamily": "Segoe UI", "fontSize": 11}],
      "stylePreset": [{"name": "BoldHeader"}]
    }},
    "card": {"*": {
      "labels": [{"color": {"solid": {"color": "#00BCD4"}}, "labelDisplayUnits": 0, "fontSize": 32, "fontFamily": "Segoe UI Light"}],
      "categoryLabels": [{"show": true, "color": {"solid": {"color": "#B0BEC5"}}, "fontSize": 10, "fontFamily": "Segoe UI"}]
    }},
    "slicer": {"*": {
      "header": [{"show": true, "fontColor": {"solid": {"color": "#00BCD4"}}, "background": {"solid": {"color": "#2A2A3E"}}, "outline": "None", "textSize": 11, "fontFamily": "Segoe UI Semibold"}],
      "items": [{"fontColor": {"solid": {"color": "#FFFFFF"}}, "outline": "None", "textSize": 11, "fontFamily": "Segoe UI"}],
      "background": [{"transparency": 100}],
      "visualHeader": [{"show": false}]
    }},
    "page": {"*": {
      "background": [{"color": {"solid": {"color": "#1E1E2E"}}, "transparency": 0}],
      "outspace": [{"color": {"solid": {"color": "#1E1E2E"}}}],
      "filterCard": [
        {"$id": "Applied", "backgroundColor": {"solid": {"color": "#00BCD4"}}, "foregroundColor": {"solid": {"color": "#1E1E2E"}}, "border": true},
        {"$id": "Available", "backgroundColor": {"solid": {"color": "#2A2A3E"}}, "foregroundColor": {"solid": {"color": "#B0BEC5"}}, "border": true}
      ]
    }}
  }
}
