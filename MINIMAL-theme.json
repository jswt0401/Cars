{
  "name": "MINIMAL",
  "dataColors": ["#1F3864","#2E75B6","#4472C4","#5B9BD5","#70AD47","#ED7D31","#FFC000","#FF0000"],
  "background": "#FFFFFF",
  "secondaryBackground": "#F2F2F2",
  "firstLevelElements": "#333333",
  "secondLevelElements": "#767676",
  "thirdLevelElements": "#E8E8E8",
  "fourthLevelElements": "#C8C8C8",
  "tableAccent": "#1F3864",
  "good": "#2E7D32",
  "neutral": "#F9A825",
  "bad": "#C62828",
  "textClasses": {
    "callout": {"fontSize": 28, "fontFace": "Segoe UI Light", "color": "#1F3864"},
    "title":   {"fontSize": 14, "fontFace": "Segoe UI Semibold", "color": "#333333"},
    "header":  {"fontSize": 11, "fontFace": "Segoe UI", "color": "#333333"},
    "label":   {"fontSize": 10, "fontFace": "Segoe UI", "color": "#767676"}
  },
  "visualStyles": {
    "*": {"*": {
      "general": [{"keepLayerOrder": true}],
      "background": [{"show": true, "color": {"solid": {"color": "#F9F9F9"}}, "transparency": 0}],
      "border": [{"show": true, "color": {"solid": {"color": "#E8E8E8"}}, "radius": 4}],
      "dropShadow": [{"show": false}],
      "visualHeader": [{"show": false}],
      "title": [{"show": true}],
      "legend": [{"show": true, "position": "Top", "labelColor": {"solid": {"color": "#767676"}}, "fontFamily": "Segoe UI", "fontSize": 10}]
    }},
    "lineChart": {"*": {
      "categoryAxis": [{"show": true, "labelColor": {"solid": {"color": "#767676"}}, "fontSize": 10, "fontFamily": "Segoe UI", "showAxisTitle": false, "gridlineShow": false}],
      "valueAxis": [{"show": true, "labelColor": {"solid": {"color": "#767676"}}, "fontSize": 10, "fontFamily": "Segoe UI", "showAxisTitle": false, "gridlineShow": true, "gridlineColor": {"solid": {"color": "#E8E8E8"}}, "gridlineThickness": 1, "gridlineStyle": "dashed"}],
      "lineStyles": [{"strokeWidth": 2, "lineStyle": "solid", "showMarker": true, "markerShape": "circle", "markerSize": 5}],
      "plotArea": [{"transparency": 0}],
      "legend": [{"show": true, "position": "Top"}]
    }},
    "clusteredColumnChart": {"*": {
      "categoryAxis": [{"show": true, "labelColor": {"solid": {"color": "#767676"}}, "fontSize": 10, "fontFamily": "Segoe UI", "showAxisTitle": false, "innerPadding": 20}],
      "valueAxis": [{"show": true, "labelColor": {"solid": {"color": "#767676"}}, "fontSize": 10, "showAxisTitle": false, "gridlineShow": true, "gridlineColor": {"solid": {"color": "#E8E8E8"}}, "gridlineThickness": 1, "gridlineStyle": "dashed"}],
      "plotArea": [{"transparency": 0}],
      "legend": [{"show": false}]
    }},
    "clusteredBarChart": {"*": {
      "categoryAxis": [{"show": true, "labelColor": {"solid": {"color": "#767676"}}, "fontSize": 10, "fontFamily": "Segoe UI", "innerPadding": 22, "showAxisTitle": false}],
      "valueAxis": [{"show": true, "labelColor": {"solid": {"color": "#767676"}}, "showAxisTitle": false, "gridlineShow": true, "gridlineColor": {"solid": {"color": "#E8E8E8"}}, "gridlineThickness": 1}],
      "plotArea": [{"transparency": 0}]
    }},
    "donutChart": {"*": {
      "legend": [{"show": true, "position": "Right", "labelColor": {"solid": {"color": "#767676"}}, "fontSize": 10}]
    }},
    "pieChart": {"*": {
      "legend": [{"show": true, "position": "Right", "labelColor": {"solid": {"color": "#767676"}}, "fontSize": 10}]
    }},
    "tableEx": {"*": {
      "grid": [{"gridVertical": false, "gridHorizontal": true, "gridHorizontalColor": {"solid": {"color": "#E8E8E8"}}, "gridHorizontalWeight": 1, "outlineColor": {"solid": {"color": "#E8E8E8"}}, "rowPadding": 4, "textSize": 11}],
      "columnHeaders": [{"fontColor": {"solid": {"color": "#333333"}}, "backColor": {"solid": {"color": "#F2F2F2"}}, "outline": "BottomOnly", "autoSizeColumnWidth": true, "fontFamily": "Segoe UI Semibold", "fontSize": 11}],
      "values": [{"fontColorPrimary": {"solid": {"color": "#333333"}}, "backColorPrimary": {"solid": {"color": "#FFFFFF"}}, "fontColorSecondary": {"solid": {"color": "#333333"}}, "backColorSecondary": {"solid": {"color": "#F9F9F9"}}, "fontFamily": "Segoe UI", "fontSize": 11}],
      "stylePreset": [{"name": "BoldHeader"}]
    }},
    "slicer": {"*": {
      "header": [{"show": true, "fontColor": {"solid": {"color": "#1F3864"}}, "background": {"solid": {"color": "#F9F9F9"}}, "outline": "None", "textSize": 11, "fontFamily": "Segoe UI Semibold"}],
      "items": [{"fontColor": {"solid": {"color": "#333333"}}, "outline": "None", "textSize": 11, "fontFamily": "Segoe UI"}],
      "background": [{"transparency": 100}],
      "visualHeader": [{"show": false}]
    }},
    "card": {"*": {
      "labels": [{"color": {"solid": {"color": "#1F3864"}}, "labelDisplayUnits": 0, "fontSize": 28, "fontFamily": "Segoe UI Light"}],
      "categoryLabels": [{"show": true, "color": {"solid": {"color": "#767676"}}, "fontSize": 10, "fontFamily": "Segoe UI"}]
    }},
    "page": {"*": {
      "background": [{"color": {"solid": {"color": "#FFFFFF"}}, "transparency": 0}],
      "outspace": [{"color": {"solid": {"color": "#F2F2F2"}}}],
      "filterCard": [
        {"$id": "Applied", "backgroundColor": {"solid": {"color": "#1F3864"}}, "foregroundColor": {"solid": {"color": "#FFFFFF"}}, "border": true},
        {"$id": "Available", "backgroundColor": {"solid": {"color": "#E8E8E8"}}, "foregroundColor": {"solid": {"color": "#333333"}}, "border": false}
      ]
    }}
  }
}
